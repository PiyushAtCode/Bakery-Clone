<% layout('layouts/boilerplate') %>

    <div class="container my-5">
        <div class="form-wrapper shadow-sm p-4 rounded-4 bg-white mx-auto fade-in" style="max-width: 550px;">
            <h2 class="text-center mb-4" style="color: #d2691e;">Create Your Account</h2>

            <form action="/singup" method="POST" class="needs-validation" novalidate>

                <div class="mb-3">
                    <label class="form-label fw-bold">Username</label>
                    <input type="text" name="username" class="form-control" required>
                    <div class="valid-feedback">Looks good!</div>
                    <div class="invalid-feedback">Please choose a username.</div>
                </div>

                <div class="mb-3">
                    <label class="form-label  fw-bold">Email</label>
                    <input type="email" name="email" class="form-control" required>
                    <div class="valid-feedback">Looks good!</div>
                    <div class="invalid-feedback">Please enter a valid email address.</div>
                </div>

                <div class="mb-4">
                    <label class="form-label    fw-bold">Password</label>
                    <input type="password" name="password" class="form-control" required minlength="8">
                    <div class="valid-feedback">Looks good!</div>
                    <div class="invalid-feedback">Please enter a password with at least 8 characters.</div>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-warning fw-bold py-2 shadow-sm">
                        Sign Up
                    </button>
                    <a href="/login" class="btn btn-outline-secondary btn-sm border-0">
                        Already have an account? Login
                    </a>
                </div>
            </form>
        </div>
    </div>
